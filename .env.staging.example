APP_ENV=staging
DEBUG=false
CORS_ALLOW_ORIGINS=https://staging-kiosco.urbani.cl,https://staging-api.urbani.cl
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/urbani_kiosco_staging
