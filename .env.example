APP_ENV=production
DEBUG=false
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# PostgreSQL — usar en docker-compose
POSTGRES_USER=urbani
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
POSTGRES_DB=urbani_kiosco
# Si corres la API fuera de Docker, ajustar manualmente:
DATABASE_URL=postgresql+psycopg2://urbani:CAMBIA_ESTA_CLAVE_SEGURA@db:5432/urbani_kiosco
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=30

# Token que usan los totems/kioscos para autenticarse (generar uno aleatorio)
KIOSK_TOKEN=genera-un-token-largo-y-aleatorio-aqui

AVERAGE_ATTENTION_MINUTES=15

MOBY_BASE_URL=https://app-api.mobysuite.com
MOBY_CLIENT_ID=
MOBY_CLIENT_SECRET=

# Roles (separados por coma)
EXECUTIVE_ALLOWED_EMAILS=ejecutivo@empresa.cl
SUPERVISOR_EMAILS=supervisor@empresa.cl
ADMIN_EMAILS=admin@empresa.cl

AUTH_SESSION_TTL_MINUTES=720
AUTH_MYSQL_ENABLED=false
AUTH_MYSQL_USER=
AUTH_MYSQL_PASSWORD=
AUTH_MYSQL_HOST=
AUTH_MYSQL_PORT=3306
AUTH_MYSQL_DATABASE=
AUTH_MYSQL_USERS_VIEW=usuarios_view
AUTH_MYSQL_EMAIL_COLUMN=correo_electronico
AUTH_MYSQL_NAME_COLUMN=nombre
AUTH_MYSQL_ACTIVE_COLUMN=activo
